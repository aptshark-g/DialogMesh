# ═══════════════════════════════════════════════════════════════════════════════
# DialogMesh — Environment Variable Template
# ═══════════════════════════════════════════════════════════════════════════════
#  Copy this file to deploy/.env (or root .env) and fill in real values.
#  DO NOT commit the actual .env file to version control.
# ───────────────────────────────────────────────────────────────────────────────

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Database
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DIALOGMESH_DB_PATH=/app/data/sessions.db
DIALOGMESH_TTL_DAYS=7

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# API Server
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DIALOGMESH_API_HOST=0.0.0.0
DIALOGMESH_API_PORT=8000
DIALOGMESH_WORKERS=4
DIALOGMESH_LOG_LEVEL=INFO

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Security (generate strong secrets with: openssl rand -hex 32)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DIALOGMESH_API_KEY=your-secret-key-here
DIALOGMESH_JWT_SECRET=your-jwt-secret-here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LLM Provider (optional — used by AgentPipeline)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DIALOGMESH_LLM_PROVIDER=openai
DIALOGMESH_OPENAI_API_KEY=sk-...
DIALOGMESH_LMSTUDIO_URL=http://localhost:1234

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Rate Limiting
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DIALOGMESH_RATE_LIMIT_RPS=10
DIALOGMESH_RATE_LIMIT_BURST=5
