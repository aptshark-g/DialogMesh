# MemoryGraph .gitignore

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# ── 虚拟环境 ──
.venv/
venv/
env/
ENV/

# ── IDE ──
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ── 数据文件（不纳入版本控制）──
data/
!data/.gitkeep
*.db
*.db-journal
*.db-wal
*.db-shm
*.graphml

# ── 模型文件（大文件）──
models/
*.bin
*.safetensors
*.pt
*.pth
*.ckpt

# ── 日志 ──
*.log
logs/

# ── 测试输出 ──
.pytest_cache/
.coverage
htmlcov/
test_reports/

# ── 环境配置（含密钥）──
config/user_config.yaml
.env
*.env

# ── 缓存 ──
.cache/
*.cache

# ── 运行时 ──
*.pid
*.sock

# ── 备份文件 ──
*.bak
*.bak.*
*.old
*.orig

# ── 其他 ──
tmp/
temp/

# ── 临时测试脚本（开发用，不提交）──
test_*.py
!tests/
!core/**/tests/
complex_test.py
interactive_test.py
stress_test.py
verify_tool_registry.py
diagnose.py
tree_panel_new.py
test_dashboard_api.py
test_dashboard_fix.py
test_final_dashboard.py
test_fixes.py
test_ui_fixes.py

eval_log.json
self.max_turns

# --- Runtime artifacts (v32 sessions, graphs, debug outputs) ---
_artifacts/
v32_graph*.json
v32_logs_*/
v32_test/
_research_downloads/
2.1
data/chat_session_*.jsonl
.venv-test/
.pytest_cache/
data/chat_session_*.jsonl
world_fixture*.pkl
_artifacts/
.hermes/
